# fastlane lanes for CardMatch (Android / Google Play).
#
# Setup once:
#   brew install fastlane
#   export SUPPLY_JSON_KEY=~/.config/play/CardMatch.play.json   # your key path
#
# Uploading requires an .aab built by Unity (Build Settings > Build App Bundle).
# Pass its path with aab:... or set AAB_PATH.

default_platform(:android)

platform :android do
  # Verify the service account can reach this app. Run this FIRST after setup —
  # it fails loudly if the key, API enablement, or Play permissions are wrong,
  # before you risk touching a real track.
  desc "Check the Play API credential works"
  lane :verify do
    validate_play_store_json_key(json_key: ENV["SUPPLY_JSON_KEY"])
    UI.success("Service account can authenticate to Google Play.")
  end

  # Upload to the internal testing track (safe: testers only, not the public).
  desc "Upload an AAB to the Internal testing track"
  lane :internal do |options|
    aab = options[:aab] || ENV["AAB_PATH"]
    UI.user_error!("Pass the bundle: fastlane internal aab:/path/to/app.aab") if aab.nil? || aab.empty?

    upload_to_play_store(
      track: "internal",
      aab: aab,
      release_status: "completed",
      skip_upload_metadata: true,   # code-only upload; leave listing/screenshots untouched
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  # Promote an already-uploaded build from a source track to Production as a
  # DRAFT, without re-uploading the .aab. Use this when the version code is
  # already on another track (a versionCode can only be uploaded once). The
  # source release is deactivated on promote, which also sunsets that track.
  #   fastlane promote version:11            # from internal (default)
  #   fastlane promote version:11 from:closed
  desc "Promote an existing build (by version code) to Production as a draft"
  lane :promote do |options|
    version = options[:version]
    UI.user_error!("Pass the version code: fastlane promote version:11") if version.nil?
    source = options[:from] || "internal"

    upload_to_play_store(
      track: source,
      track_promote_to: "production",
      version_code: version.to_i,
      # For a PROMOTE, the promoted release status is set by
      # track_promote_release_status, NOT release_status. "draft" keeps it
      # unpublished until you press publish in the Console.
      track_promote_release_status: "draft",
      skip_upload_aab: true,                # promote only, no re-upload
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end

  # Upload to production as a DRAFT (nothing goes live until you press publish
  # in the Play Console). Deliberately not a one-command full rollout.
  desc "Upload an AAB to Production as a draft (manual publish in Console)"
  lane :production_draft do |options|
    aab = options[:aab] || ENV["AAB_PATH"]
    UI.user_error!("Pass the bundle: fastlane production_draft aab:/path/to/app.aab") if aab.nil? || aab.empty?

    upload_to_play_store(
      track: "production",
      aab: aab,
      release_status: "draft",      # <-- draft, not live
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
