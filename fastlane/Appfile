# fastlane Appfile — identifies the app and the Play credential.
# The service-account key path comes from an env var so the JSON never lives
# in the repo. Set it before running fastlane, e.g.:
#   export SUPPLY_JSON_KEY=~/.config/play/CardMatch.play.json
json_key_file(ENV["SUPPLY_JSON_KEY"])
package_name("com.MagicPotionStudios.CardMatch")
